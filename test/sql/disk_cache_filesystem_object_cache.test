# name: test/sql/disk_cache_filesystem_object_cache.test
# description: Disk reader's in-mem layer under `object_cache` storage mode.
# group: [sql]

require notwindows

require cache_httpfs

require parquet

statement ok
SET cache_httpfs_in_mem_cache_storage='object_cache';

statement ok
SET cache_httpfs_type='on_disk';

statement ok
SET cache_httpfs_cache_block_size=1048576;

statement ok
SET cache_httpfs_cache_directory='/tmp/duckdb_cache_httpfs_cache';

statement ok
SELECT cache_httpfs_clear_cache();

query IIIII
SELECT * FROM cache_httpfs_cache_status_query();
----

# After a read, the in-mem-disk-cache row sourced from ObjectCache must appear.
query I
SELECT COUNT(*) FROM read_csv_auto('https://raw.githubusercontent.com/dentiny/duck-read-cache-fs/refs/heads/main/test/data/stock-exchanges.csv?cache_test=1');
----
251

query I
SELECT COUNT(*) FROM cache_httpfs_cache_status_query() WHERE cache_type = 'in-mem-disk-cache';
----
1

# Clearing the cache.
statement ok
SELECT cache_httpfs_clear_cache();

query I
SELECT COUNT(*) FROM cache_httpfs_cache_status_query() WHERE cache_type = 'in-mem-disk-cache';
----
0
