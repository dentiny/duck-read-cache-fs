# name: test/sql/cache_block_size.test
# description: power-of-two cache block size validation and in-memory remap visible via cache_httpfs_cache_status_query
# group: [sql]

require cache_httpfs

statement ok
SET cache_httpfs_type='in_mem';

statement ok
SELECT cache_httpfs_clear_cache();

# Non power-of-two block sizes are rejected.
statement error
SET cache_httpfs_cache_block_size=1000000;
----
cache_httpfs_cache_block_size must be a power of two

statement ok
SELECT cache_httpfs_clear_cache();

# stock-exchanges.csv is 16222 bytes. Use 8192-byte blocks: two cached spans [0, 8192) and [8192, 16222).
statement ok
SET cache_httpfs_cache_block_size=8192;

statement ok
SELECT COUNT(*) FROM read_csv_auto('https://raw.githubusercontent.com/dentiny/duck-read-cache-fs/refs/heads/main/test/data/stock-exchanges.csv?cache_block_size_remap=1');

# Cache keys use StripQueryAndFragment; status rows use the URL without ?foo=.
query II
SELECT start_offset, end_offset FROM cache_httpfs_cache_status_query() WHERE original_remote_path = 'https://raw.githubusercontent.com/dentiny/duck-read-cache-fs/refs/heads/main/test/data/stock-exchanges.csv' ORDER BY start_offset;
----
0	8192
8192	16222

# Smaller Po2 grid splits the contiguous run into three spans without clearing cache.
statement ok
SET cache_httpfs_cache_block_size=4096;

query II
SELECT start_offset, end_offset FROM cache_httpfs_cache_status_query() WHERE original_remote_path = 'https://raw.githubusercontent.com/dentiny/duck-read-cache-fs/refs/heads/main/test/data/stock-exchanges.csv' ORDER BY start_offset;
----
0	4096
4096	8192
8192	12288
12288	16222

# Cached bytes should still satisfy a follow-up read.
query I
SELECT COUNT(*) FROM read_csv_auto('https://raw.githubusercontent.com/dentiny/duck-read-cache-fs/refs/heads/main/test/data/stock-exchanges.csv?cache_block_size_remap=1');
----
251

statement ok
SELECT cache_httpfs_clear_cache();
